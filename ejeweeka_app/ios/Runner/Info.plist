<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- ═══ App Identity ═══════════════════════════════════════════ -->
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
	<string>ejeweeka</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
	<string>ejeweeka</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!-- ═══ Privacy Permissions ════════════════════════════════════ -->
		<!-- Camera — required for food photo analysis (PH-1) -->
		<key>NSCameraUsageDescription</key>
		<string>ejeweeka использует камеру для анализа блюд и подсчёта калорий. Данные не хранятся на сервере.</string>
		<!-- Photo Library — for picking existing photos -->
		<key>NSPhotoLibraryUsageDescription</key>
		<string>ejeweeka может читать фото блюд из галереи для подсчёта КБЖУ.</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>ejeweeka сохраняет фото блюд в галерею для истории питания.</string>
		<!-- Health — future Apple Health integration (HC-1) -->
		<key>NSHealthShareUsageDescription</key>
		<string>ejeweeka читает данные о весе, активности и сне из Apple Health для точной персонализации плана питания.</string>
		<key>NSHealthUpdateUsageDescription</key>
		<string>ejeweeka записывает данные о питании и калориях в Apple Health для синхронизации прогресса.</string>
		<!-- Notifications — for meal reminders and plan updates -->
		<key>UIBackgroundModes</key>
		<array>
			<string>remote-notification</string>
		</array>
		<!-- ═══ App Transport Security ══════════════════════════════════ -->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<false/>
			<key>NSExceptionDomains</key>
			<dict>
				<!-- Production API (Render) -->
				<key>ejeweeka-api.onrender.com</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<false/>
					<key>NSIncludesSubdomains</key>
					<true/>
				</dict>
				<!-- Dev only: localhost -->
				<key>localhost</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<true/>
				</dict>
			</dict>
		</dict>
		<!-- ═══ UI Configuration ══════════════════════════════════════ -->
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<!-- Portrait-only for onboarding; landscape allowed in main app -->
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<!-- ═══ App Store Metadata ═══════════════════════════════════ -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
		<!-- Minimum iOS version (set in Podfile too) -->
		<key>MinimumOSVersion</key>
		<string>14.0</string>
		<key>UIStatusBarHidden</key>
		<true/>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
	</dict>
</plist>
